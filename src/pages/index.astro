---
import BlogLayout from '/src/layouts/BlogLayout.astro';
import { fetchPosts, getImageUrl } from '../lib/strapi';

const posts = await fetchPosts();
---

<BlogLayout title="My Blog - Home">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero Section -->
    <div class="text-center mb-16">
      <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
        My Blog
      </h1>
      <p class="mt-3 max-w-md mx-auto text-base text-gray-500 sm:text-lg md:mt-5 md:text-xl md:max-w-3xl">
        Thoughts, stories, and ideas worth sharing
      </p>
    </div>

    <!-- Search Bar -->
    <div class="max-w-xl mx-auto mb-8">
      <input 
        type="text" 
        id="search-input"
        placeholder="Search posts by title or description..." 
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent shadow-sm"
      />
    </div>

    <!-- Blog Posts Grid -->
    <div id="posts-grid" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {posts.length > 0 ? (
        posts.map((post) => (
          <article 
            class="post-card bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 flex flex-col h-full"
            data-title={post.Title.toLowerCase()}
            data-description={post.Description.toLowerCase()}
          >
            {/* Cover Image */}
            {post.Cover && (
              <div class="flex-shrink-0">
                <img 
                  class="h-48 w-full object-cover"
                  src={getImageUrl(post.Cover)}
                  alt={post.Title}
                />
              </div>
            )}
            <div class="flex-1 p-6 flex flex-col justify-between">
              <div class="flex-1">
                {/* Categories */}
                {post.categories && post.categories.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-3">
                    {post.categories.map((category) => (
                      <a
                        href={`/categories/${category.Slug}`}
                        class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full hover:bg-gray-200 transition-colors"
                      >
                        {category.Name}
                      </a>
                    ))}
                  </div>
                )}
                
                <h2 class="text-xl font-semibold text-gray-900 mb-2">
                  <a href={`/posts/${post.Slug}`} class="hover:text-blue-600 transition-colors">
                    {post.Title}
                  </a>
                </h2>
                <p class="text-gray-600 mb-4">{post.Description}</p>
              </div>
              <a 
                href={`/posts/${post.Slug}`} 
                class="text-blue-600 hover:text-blue-800 font-medium inline-flex items-center"
              >
                Read more 
                <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          </article>
        ))
      ) : (
        <div class="text-center py-12 col-span-full">
          <p class="text-gray-500 text-lg">No blog posts yet. Check back soon!</p>
        </div>
      )}
    </div>

    <!-- No Results Message -->
    <div id="no-results" class="hidden text-center py-12 col-span-full">
      <p class="text-gray-500 text-lg">No posts match your search. Try different keywords!</p>
    </div>

    <!-- Newsletter Signup -->
    <div class="max-w-2xl mx-auto mt-16 p-8 bg-gradient-to-r from-blue-500 to-purple-600 rounded-2xl text-white shadow-xl">
      <h3 class="text-2xl font-bold mb-2">Never miss a post</h3>
      <p class="text-blue-100 mb-6">Get the latest articles straight to your inbox</p>
      <form class="flex flex-col sm:flex-row gap-3">
        <input 
          type="email" 
          placeholder="Your email address" 
          class="flex-1 px-4 py-3 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-300 focus:outline-none"
          required
        />
        <button class="px-6 py-3 bg-white text-blue-600 rounded-lg font-medium hover:bg-blue-50 transition-colors shadow-md">
          Subscribe
        </button>
      </form>
      <p class="text-xs text-blue-200 mt-4">We respect your privacy. Unsubscribe at any time.</p>
    </div>
  </div>
</BlogLayout>

<script>
  // Search functionality
  const searchInput = document.getElementById('search-input');
  const postsGrid = document.getElementById('posts-grid');
  const noResults = document.getElementById('no-results');
  const postCards = document.querySelectorAll('.post-card');

  searchInput.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase().trim();
    let visibleCount = 0;

    postCards.forEach(card => {
      const title = card.dataset.title;
      const description = card.dataset.description;
      const matches = title.includes(query) || description.includes(query);
      
      if (matches || query === '') {
        card.style.display = 'flex';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    // Show/hide no results message
    if (visibleCount === 0 && query !== '') {
      noResults.classList.remove('hidden');
      postsGrid.classList.add('hidden');
    } else {
      noResults.classList.add('hidden');
      postsGrid.classList.remove('hidden');
    }
  });
</script>