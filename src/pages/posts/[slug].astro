---
import BlogLayout from '/src/layouts/BlogLayout.astro';
import { fetchPosts, fetchPostBySlug, fetchRelatedPosts, getImageUrl } from '../../lib/strapi';
import { marked } from 'marked';

// Configure marked for better Markdown rendering
marked.setOptions({
  breaks: true, // Convert line breaks to <br>
  gfm: true, // GitHub Flavored Markdown
  headerIds: true, // Enable header IDs for table of contents
});

// Helper function to calculate reading time
function getReadingTime(content) {
  const wordsPerMinute = 200;
  const wordCount = content.split(/\s+/).length;
  const minutes = Math.ceil(wordCount / wordsPerMinute);
  return `${minutes} min read`;
}

// Generate table of contents
function generateTOC(content) {
  const headings = content.match(/^#{1,3} .+$/gm) || [];
  return headings.map(heading => {
    const level = heading.match(/^#+/)[0].length;
    const text = heading.replace(/^#+\s/, '');
    const slug = text.toLowerCase().replace(/[^\w]+/g, '-');
    return { level, text, slug };
  });
}

export async function getStaticPaths() {
  const posts = await fetchPosts();
  return posts.map((post) => ({
    params: { slug: post.Slug },
  }));
}

const { slug } = Astro.params;
const post = await fetchPostBySlug(slug);
const relatedPosts = post ? await fetchRelatedPosts(post, 3) : [];

// Convert Markdown to HTML
const contentHtml = post ? marked.parse(post.Content) : '';

// Calculate reading time
const readingTime = post ? getReadingTime(post.Content) : '';

// Generate table of contents
const toc = post ? generateTOC(post.Content) : [];

// Get current URL for sharing
const currentUrl = `https://yourblog.com/posts/${post?.Slug}`; // Replace with your actual domain
---

<BlogLayout title={post?.Title ? `${post.Title} - My Blog` : 'Post Not Found'}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {post ? (
      <article>
        <!-- Back link -->
        <a 
          href="/" 
          class="inline-flex items-center text-gray-600 hover:text-gray-900 mb-8 group"
        >
          <svg class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
          Back to all posts
        </a>

        <!-- Cover Image -->
        {post.Cover && (
          <div class="mb-8 rounded-lg overflow-hidden shadow-lg">
            <img 
              src={getImageUrl(post.Cover)}
              alt={post.Title}
              class="w-full h-[400px] object-cover"
            />
          </div>
        )}

        <!-- Post Header -->
        <header class="mb-8">
          <!-- Categories -->
          {post.categories && post.categories.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
              {post.categories.map((category) => (
                <a
                  href={`/categories/${category.Slug}`}
                  class="text-sm bg-gray-100 text-gray-600 px-3 py-1 rounded-full hover:bg-gray-200 transition-colors"
                >
                  {category.Name}
                </a>
              ))}
            </div>
          )}
          
          <h1 class="text-4xl font-bold text-gray-900 mb-4">{post.Title}</h1>
          
          <!-- Post Meta with Reading Time -->
          <div class="flex items-center gap-4 text-gray-500 text-sm">
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
              </svg>
              {new Date(post.publishedAt || post.createdAt).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </div>
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {readingTime}
            </div>
          </div>
        </header>

        <!-- Table of Contents (if there are headings) -->
        {toc.length > 0 && (
          <div class="bg-gray-50 p-6 rounded-lg mb-8 border border-gray-200">
            <h3 class="font-semibold text-gray-900 mb-3 flex items-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
              </svg>
              Table of Contents
            </h3>
            <nav class="space-y-1">
              {toc.map(item => (
                <a 
                  href={`#${item.slug}`}
                  class={`block text-gray-600 hover:text-blue-600 transition-colors text-sm ${item.level > 1 ? 'ml-4' : ''}`}
                >
                  {item.text}
                </a>
              ))}
            </nav>
          </div>
        )}

        <!-- Post Content -->
        <div 
          class="max-w-3xl"
          set:html={contentHtml} 
        />

        <!-- Share Buttons -->
        <div class="mt-12 pt-8 border-t border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Share this post</h3>
          <div class="flex gap-3">
            <!-- Twitter -->
            <a 
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.Title)}&url=${encodeURIComponent(currentUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="p-3 bg-[#1DA1F2] text-white rounded-lg hover:opacity-90 transition-opacity"
              aria-label="Share on Twitter"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.104c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 0021.82-12.332c.01-.21.015-.42.015-.63A9.935 9.935 0 0024 4.59z"/>
              </svg>
            </a>
            
            <!-- LinkedIn -->
            <a 
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(currentUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="p-3 bg-[#0A66C2] text-white rounded-lg hover:opacity-90 transition-opacity"
              aria-label="Share on LinkedIn"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            
            <!-- Copy Link -->
            <button 
              id="copy-link-btn"
              class="p-3 bg-gray-600 text-white rounded-lg hover:opacity-90 transition-opacity relative"
              aria-label="Copy link"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Related Posts Section -->
        {relatedPosts.length > 0 && (
          <div class="mt-16 pt-8 border-t">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">You might also like</h2>
            <div class="grid gap-6 md:grid-cols-3">
              {relatedPosts.map((related) => (
                <a 
                  href={`/posts/${related.Slug}`}
                  class="group block"
                >
                  {related.Cover && (
                    <div class="aspect-w-16 aspect-h-9 mb-3 overflow-hidden rounded-lg">
                      <img 
                        src={getImageUrl(related.Cover)}
                        alt={related.Title}
                        class="w-full h-32 object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                    </div>
                  )}
                  <h3 class="font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2">
                    {related.Title}
                  </h3>
                  <p class="text-sm text-gray-500 mt-1 line-clamp-2">
                    {related.Description}
                  </p>
                </a>
              ))}
            </div>
          </div>
        )}
      </article>
    ) : (
      <div class="text-center py-12">
        <h1 class="text-2xl font-bold text-gray-900 mb-4">Post Not Found</h1>
        <p class="text-gray-600 mb-8">The post you're looking for doesn't exist.</p>
        <a 
          href="/" 
          class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors"
        >
          Go back home
        </a>
      </div>
    )}
  </div>
</BlogLayout>

<script>
  // Copy link functionality
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const url = window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        
        // Show temporary success message
        const originalHtml = copyBtn.innerHTML;
        copyBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
        copyBtn.classList.add('bg-green-600');
        
        setTimeout(() => {
          copyBtn.innerHTML = originalHtml;
          copyBtn.classList.remove('bg-green-600');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  }
</script>